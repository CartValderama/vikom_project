<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingHorizontal="@dimen/padding_large"
    android:paddingTop="4dp"
    android:paddingBottom="2dp">

    
    <LinearLayout
        android:id="@+id/tab_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tab_quick_dial"
            android:layout_width="0dp"
            android:layout_height="@dimen/tab_height"
            android:layout_weight="1"
            android:text="@string/tab_quick_dial"
            android:textSize="@dimen/tab_text_size"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:background="@drawable/tab_button_first_inactive"
            android:focusable="true"
            android:clickable="true"
            android:defaultFocusHighlightEnabled="false"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tab_contacts"
            android:layout_width="0dp"
            android:layout_height="@dimen/tab_height"
            android:layout_weight="1"
            android:text="@string/tab_contacts"
            android:textSize="@dimen/tab_text_size"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:background="@drawable/tab_button_last_active"
            android:focusable="true"
            android:clickable="true"
            android:defaultFocusHighlightEnabled="false"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/content_area_background"
        android:padding="8dp">

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/search_bar_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#EDEDED">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="🔍"
                    android:textSize="@dimen/tab_text_size"
                    android:gravity="center"
                    tools:ignore="HardcodedText" />

                <EditText
                    android:id="@+id/search_input"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Søk"
                    android:textSize="@dimen/text_body"
                    android:textColor="#000000"
                    android:textColorHint="#9E9E9E"
                    android:background="@android:color/transparent"
                    android:inputType="text"
                    android:paddingEnd="8dp"
                    android:nextFocusDown="@id/contacts_list"
                    tools:ignore="VisualLintTextFieldSize,HardcodedText,Autofill" />

                <TextView
                    android:id="@+id/btn_clear_search"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="✕"
                    android:textSize="@dimen/tab_text_size"
                    android:textColor="#616161"
                    android:gravity="center"
                    android:background="@android:color/transparent"
                    android:focusable="true"
                    android:clickable="true"
                    android:defaultFocusHighlightEnabled="false"
                    android:visibility="gone"
                    tools:ignore="HardcodedText" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_search"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="SØK"
                android:textSize="@dimen/search_button_text"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingHorizontal="20dp"
                android:background="@drawable/button_search_background"
                android:focusable="true"
                android:clickable="true"
                android:defaultFocusHighlightEnabled="false"
                android:layout_marginStart="8dp"
                tools:ignore="HardcodedText" />
        </LinearLayout>

        
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/contacts_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants" />

    </LinearLayout>

</LinearLayout>
