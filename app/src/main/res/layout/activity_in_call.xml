<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/call_screen_background"
    tools:context=".ui.activities.InCallActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="@dimen/padding_xlarge"
        android:paddingBottom="@dimen/padding_large">

        
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        
        <TextView
            android:id="@+id/txt_contact_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contact Name"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_caller_name"
            android:textStyle="bold"
            android:fontFamily="sans-serif-bold" />

        
        <TextView
            android:id="@+id/txt_contact_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_call_status"
            android:visibility="gone" />

        
        <TextView
            android:id="@+id/txt_call_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connected"
            android:textColor="#E0E0E0"
            android:textSize="@dimen/text_call_status"
            android:layout_marginTop="2dp" />

        
        <ImageView
            android:id="@+id/img_contact_avatar"
            android:layout_width="@dimen/call_avatar_size"
            android:layout_height="@dimen/call_avatar_size"
            android:layout_marginTop="@dimen/padding_standard"
            android:background="@drawable/call_avatar_circle"
            android:contentDescription="Contact Avatar"
            android:scaleType="centerCrop" />

        
        <TextView
            android:id="@+id/txt_call_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_standard"
            android:text="00:00:00"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/text_call_timer"
            android:fontFamily="sans-serif-light" />

        
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        
        <TextView
            android:id="@+id/txt_mute_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Muted"
            android:textColor="#f39c12"
            android:textSize="@dimen/text_body"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txt_speaker_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        
        <LinearLayout
            android:id="@+id/call_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            
            <ImageButton
                android:id="@+id/btn_mute"
                android:layout_width="@dimen/button_in_call"
                android:layout_height="@dimen/button_in_call"
                android:background="@drawable/call_btn_action"
                android:src="@drawable/ic_mic"
                android:scaleType="centerInside"
                android:padding="@dimen/in_call_button_padding"
                android:stateListAnimator="@null"
                android:focusable="true"
                android:defaultFocusHighlightEnabled="false"
                android:contentDescription="Mute" />

            
            <ImageButton
                android:id="@+id/btn_hang_up"
                android:layout_width="@dimen/button_call_action"
                android:layout_height="@dimen/button_call_action"
                android:layout_marginHorizontal="@dimen/call_button_spacing"
                android:background="@drawable/call_btn_hangup"
                android:src="@drawable/ic_call_end"
                android:scaleType="centerInside"
                android:padding="@dimen/call_button_padding"
                android:stateListAnimator="@null"
                android:focusable="true"
                android:defaultFocusHighlightEnabled="false"
                android:contentDescription="End Call" />

            
            <ImageButton
                android:id="@+id/btn_speaker"
                android:layout_width="@dimen/button_in_call"
                android:layout_height="@dimen/button_in_call"
                android:background="@drawable/call_btn_action"
                android:src="@drawable/ic_speaker"
                android:scaleType="centerInside"
                android:padding="@dimen/in_call_button_padding"
                android:stateListAnimator="@null"
                android:focusable="true"
                android:defaultFocusHighlightEnabled="false"
                android:contentDescription="Speaker" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
