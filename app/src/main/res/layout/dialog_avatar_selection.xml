<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/choose_avatar"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="20dp" />

    
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="12dp">

        <ImageView
            android:id="@+id/avatar_blue"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_blue"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Blue avatar" />

        <ImageView
            android:id="@+id/avatar_green"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_green"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Green avatar" />

        <ImageView
            android:id="@+id/avatar_red"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_red"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Red avatar" />

    </LinearLayout>

    
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageView
            android:id="@+id/avatar_purple"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_purple"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Purple avatar" />

        <ImageView
            android:id="@+id/avatar_orange"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_orange"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Orange avatar" />

        <ImageView
            android:id="@+id/avatar_teal"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/avatar_teal"
            android:padding="4dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background"
            android:layout_marginHorizontal="8dp"
            android:contentDescription="Teal avatar" />

    </LinearLayout>

    <Button
        android:id="@+id/btn_remove_avatar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/button_remove_outline_background"
        android:focusable="true"
        android:clickable="true"
        android:stateListAnimator="@null"
        android:text="@string/remove_photo"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:padding="10dp" />

</LinearLayout>
