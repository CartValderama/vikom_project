<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/default_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="@dimen/padding_standard">

        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/profile_title"
            android:textColor="#212121"
            android:textSize="@dimen/contact_detail_name"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_large" />

        
        <FrameLayout
            android:id="@+id/avatar_container"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/button_favorite_background">

            <ImageView
                android:id="@+id/img_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Profilbilde"
                android:background="@drawable/call_avatar_circle" />

            
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/button_primary_background"
                android:padding="6dp"
                android:src="@drawable/ic_edit_pencil"
                android:scaleType="fitCenter"
                android:contentDescription="Change photo"
                android:focusable="false"
                android:clickable="false" />
        </FrameLayout>

        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/padding_large"
            android:paddingHorizontal="@dimen/padding_standard">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/username_label"
                android:textColor="#616161"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txt_username"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:text=""
                android:textColor="#212121"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/input_field_background"
                android:focusable="true"
                android:clickable="true"
                android:drawableEnd="@android:drawable/ic_menu_edit" />
        </LinearLayout>

        
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        
        <TextView
            android:id="@+id/btn_go_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/button_height"
            android:text="@string/go_back"
            android:textSize="@dimen/text_body"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/button_secondary_background"
            android:padding="@dimen/padding_standard"
            android:layout_marginHorizontal="@dimen/padding_standard"
            android:focusable="true"
            android:clickable="true" />

    </LinearLayout>

</ScrollView>
