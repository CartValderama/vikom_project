<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="@dimen/auth_padding"
    android:background="@color/default_background">

    <TextView
        android:id="@+id/txt_verification_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/padding_standard"
        android:text="@string/email_verification_title"
        android:textColor="#212121"
        android:textSize="@dimen/text_title"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txt_verification_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/input_max_width"
        android:maxWidth="@dimen/input_max_width"
        android:layout_marginBottom="@dimen/padding_large"
        android:gravity="center"
        android:textColor="#616161"
        android:textSize="@dimen/text_body"
        android:lineSpacingMultiplier="1.4" />

    <LinearLayout
        style="?android:attr/buttonBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minWidth="@dimen/input_max_width"
        android:maxWidth="@dimen/input_max_width"
        android:gravity="center">

        <Button
            android:id="@+id/btn_resend_email"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:stateListAnimator="@null"
            android:background="@drawable/button_primary_background"
            android:text="@string/resend_email_button"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="@dimen/text_body"
            android:padding="@dimen/padding_standard" />

        <Button
            android:id="@+id/btn_back_to_login"
            style="?android:attr/buttonBarButtonStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:stateListAnimator="@null"
            android:background="@drawable/button_secondary_background"
            android:text="@string/back_to_login_button"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textSize="@dimen/text_body"
            android:padding="@dimen/padding_standard" />

    </LinearLayout>

</LinearLayout>
